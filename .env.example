# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-...

# Agency identity (used in the twin's persona + tool responses)
AGENCY_NAME=Northlight Studio
FOUNDER_NAME=Raymund
BOOKING_LINK=https://cal.com/your-handle/intro
TIMEZONE=Asia/Manila

# Model overrides (optional). Defaults below.
# claude-opus-4-8  = flagship, best voice + sales reasoning
# claude-haiku-4-5 = fastest/cheapest, use if you need to cut cost
TWIN_CHAT_MODEL=claude-opus-4-8
TWIN_CONTENT_MODEL=claude-opus-4-8
